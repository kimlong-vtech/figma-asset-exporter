{
  "name": "figma-tool",
  "displayName": "Figma Tool",
  "description": "A simple VS Code extension to export Figma assets via a local server.",
  "version": "0.0.1",
  "repository": "https://github.com/example/figma-tool",
  "publisher": "local",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:figmaSidebarView"
  ],
  "main": "./src/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "figmaSidebarContainer",
          "title": "Figma",
          "icon": "media/figma.svg"
        }
      ]
    },
    "views": {
      "figmaSidebarContainer": [
        {
          "id": "figmaSidebarView",
          "name": "Figma",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "build": "npm --prefix figma-plugin run build && echo \"Figma plugin built\"",
    "lint": "echo \"No lint configured\"",
    "package": "npm run build && npx vsce package",
    "test": "echo \"No tests configured\""
  },
  "devDependencies": {
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1"
  }
}

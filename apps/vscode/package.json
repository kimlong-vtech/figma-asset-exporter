{
  "name": "assetport-figma",
  "displayName": "assetport-figma",
  "description": "Export Figma assets directly to your VS Code workspace.",
  "version": "0.1.1",
  "publisher": "kimlonghok",
  "repository": "https://github.com/kimlonghok/assetport",
  "engines": {
    "vscode": "^1.90.0"
  },
  "license": "MIT",
  "categories": [
    "Other"
  ],
  "galleryBanner": {
    "color": "#1a1e2e",
    "theme": "dark"
  },
  "keywords": [
    "figma",
    "assets",
    "export",
    "design"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "icon.png",
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "assetport.startServer",
        "title": "assetport: Start Export Server"
      },
      {
        "command": "assetport.stopServer",
        "title": "assetport: Stop Export Server"
      }
    ]
  },
  "scripts": {
    "build": "node esbuild.js",
    "dev": "node esbuild.js --watch",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "package": "pnpm run typecheck && node esbuild.js --production && npx vsce package --no-dependencies",
    "package:all": "pnpm run typecheck && node scripts/package-targets.js"
  },
  "devDependencies": {
    "@assetport/shared": "workspace:*",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.1",
    "esbuild": "^0.28.1",
    "typescript": "^5.5.0"
  },
  "dependencies": {
    "@napi-rs/image": "^1.12.1"
  }
}
